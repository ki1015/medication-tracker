      "bundleIdentifier": "com.medicationtracker.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0f172a"
      },
      "package": "com.medicationtracker.app"
    },
    "plugins": [
      "expo-asset"
    ]
  }
}
